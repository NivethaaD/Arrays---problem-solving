7.Rotate Array

class Solution:
    def rotate(self, nums: List[int], k: int) -> None:
        n = len(nums)
        k = k%n
        nums[:] = nums[::-1]
        nums[:k] = nums[:k][::-1]
        nums[k:] = nums[k:][::-1]
    
8.Move Zeroes

class Solution:
    def moveZeroes(self, nums: List[int]) -> None:
        k = 0
        for ele in nums:
            if ele != 0:
                nums[k]=ele
                k = k + 1
        nums[k:] = [0]*len(nums[k:])
        
