16. Two Sum

class Solution:
    def twoSum(self, nums: List[int], target: int) -> List[int]:
        seen = {}
        for i, num in enumerate(nums):
            diff = target - num
            if diff in seen:
                return [seen[diff],i]
            seen[num]=i
        return [-1,-1]

17. Sort Colors - Dutch National Flag algorithm.

class Solution:
    def sortColors(self, nums: List[int]) -> None:
        l = 0
        m = 0
        h = len(nums)-1
        
        while m<=h:
            if nums[m]==0:
                nums[l],nums[m]=nums[m],nums[l]
                l = l + 1
                m = m + 1
            elif nums[m]==1:
                m = m + 1
            else:
                nums[m],nums[h]=nums[h],nums[m]
                h = h - 1

18. Majority Element - Moore's Voting Algorithm

class Solution:
    def majorityElement(self, nums: List[int]) -> int:
        ele = nums[0]
        count = 0
        for val in nums:
            if count == 0:
                ele = val
            if ele == val:
                count = count+1
            else:
                count = count-1
        return ele

19. Maximum Subarray (Kadane's Algorithm):

class Solution:
    def maxSubArray(self, nums: List[int]) -> int:
        sum = 0
        maxi = float('-inf')
        for ele in nums:
            if sum < 0:
                sum = 0
            sum = sum + ele
            maxi = max(maxi,sum)
        return maxi

20. Best Time to Buy and Sell Stock:

class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        min_price = float('inf')
        max_profit = 0

        for price in prices:
            min_price = min(min_price,price)
            max_profit = max(max_profit, price-min_price)

        return max_profit

