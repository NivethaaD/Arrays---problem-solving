3.Check if Array Is Sorted and Rotated

class Solution:
    def check(self, nums: List[int]) -> bool:
        temp = nums.copy()
        temp.sort()
        n = len(nums)
        breakPoint = -1
        for i in range(0,n):
            if nums[i] < nums[i-1]:
                breakPoint = i
        
        nums[:breakPoint] = nums[:breakPoint][::-1]
        nums[breakPoint:] = nums[breakPoint:][::-1]
        nums.reverse()

        if nums == temp:
            return True
        return False

4.Check if array is sorted

class Solution:
    def isSorted(self, arr) -> bool:
        # code here
        n = len(arr)
        for i in range(0,n-1):
            if arr[i]>arr[i+1]:
                return False
        return True
                

        
