12.Max Consecutive Ones

class Solution:
    def findMaxConsecutiveOnes(self, nums: List[int]) -> int:
        MaxCount = 0
        oneCount = 0
        n = len(nums)
        for i in range(0,n):
            if nums[i]==1:
                oneCount=oneCount+1
            else:
                if oneCount > MaxCount:
                    MaxCount = oneCount
                oneCount = 0

        if oneCount > MaxCount:
            MaxCount = oneCount

        return MaxCount

13.Single Number

class Solution:
    def singleNumber(self, nums: List[int]) -> int:
        """
        Important intuition
        XOR acts like a “pair remover”.
        Every duplicate number disappears:
        a⊕a=0
        Only the single number remains.
        """
        
        result = 0
        for ele in nums:
            result = result^ele
        return result

14. Longest Subarray with Sum K

class Solution:
    def longestSubarray(self, arr, k):  
        sum = 0
        d = {}
        ans = 0
        for i in range(0,len(arr)):
            sum = sum+arr[i]
            
            if sum == k:
                ans = i+1
            
            if (sum-k) in d:
                ans = max(ans,i-d[sum-k])
            
            if sum not in d:
                d[sum]=i
        
        return ans
    
