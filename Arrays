            else:
                ans[j] = ele
                j = j + 2
        return ans

22. Array Leaders

class Solution:
    def leaders(self, arr):
        rightMax = float('-inf')
        n = len(arr)
        ans = list()
        for i in range(n-1,-1,-1):
            if arr[i] >= rightMax:
                ans.append(arr[i])
                rightMax = arr[i]
        
        i = 0
        j = len(ans)-1
        
        while i<j:
            ans[i],ans[j] = ans[j],ans[i]
            i = i+1
            j = j-1
        
        return ans
    
23. Longest Consecutive Sequence

class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        temp = set(nums)
        maxiLength = 0

        for ele in temp:
            count = 1
            if ele-1 in temp:
                continue

            num = ele
            while True:
                if num+1 in temp:
                    count = count+1
                    num = num + 1
                else:
                    break
                    
            maxiLength = max(maxiLength, count)
        return maxiLength
            
